CREATE DATABASE AND SCHEMA
-CREATES A NEW DATABASE AND CHECKING IF IT EXISTS, IF IT EXISTS WE ARE DROPPING IT AND CREATING THE DATABASE WITH NEW SCHEMAS;
BRONZE, SILVER & GOLD. 

WARNING: 
RUNNING THE SCRIPT WILL DROP THE ENTIRE DATABASE AND LOSE ALL THE DATA IN THE DATABASE.


USE MASTER;

GO 

-- Before creating a database, we must first check if it exists and if it does, we drop it and create a new one. 

IF EXISTS( SELECT 1 FROM SYS.DATABASES WHERE NAME = 'DATAWAREHOUSE')
BEGIN 
	ALTER DATABASE DATAWAREHOUSE SET SINGLE_USER WITH ROLLBACK IMMEDIATE;
	DROP DATABASE DATAWAREHOUSE;
END;

GO

CREATE SCHEMA bronze;
Go
CREATE SCHEMA silver;
Go -- The go command is a separator, which tells sql, execute this then move to the next one.
CREATE SCHEMA gold;
Go
